{
  "manifest_version": 3,
  "name": "Riftbound Game Recorder",
  "version": "0.1.0",
  "description": "Capture and review your Riftbound games on tcg-arena.fr",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "tabs", "scripting"],
  "host_permissions": ["https://tcg-arena.fr/*"],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Riftbound Recorder",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://tcg-arena.fr/*"],
      "js": ["src/content-game.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://loutrinos.github.io/wdip/*",
        "http://localhost:5173/*"
      ],
      "js": ["src/content-bridge.ts"],
      "run_at": "document_idle"
    }
  ]
}
